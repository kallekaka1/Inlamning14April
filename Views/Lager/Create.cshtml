@model MorMorsBageruMVC.Models.Lager

@{
    ViewData["Title"] = "Lägg till Lagerpost";
}

<h1>Lägg till Lagerpost</h1>

<form asp-action="Create">

    <div class="form-group">
        <label>Råvara ID</label>
        <input asp-for="RåvaraId" class="form-control" />
    </div>

    <div class="form-group">
        <label>Mängd (kg)</label>
        <input asp-for="MängdKg" class="form-control" />
    </div>

    <button class="btn btn-success">Spara</button>
    <a asp-action="Index" class="btn btn-secondary">Tillbaka</a>
</form>