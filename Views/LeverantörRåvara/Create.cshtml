@model MorMorsBageruMVC.Models.LeverantörRåvara

@{
    ViewData["Title"] = "Skapa Koppling";
}

<h1>Lägg till Koppling</h1>

<form asp-action="Create">

    <div class="form-group">
        <label>Leverantör ID</label>
        <input asp-for="LeverantörId" class="form-control" />
    </div>

    <div class="form-group">
        <label>Råvara ID</label>
        <input asp-for="RåvaraId" class="form-control" />
    </div>

    <button class="btn btn-success">Spara</button>
    <a asp-action="Index" class="btn btn-secondary">Tillbaka</a>

</form>