@model MorMorsBageruMVC.Models.LeverantörRåvara

@{
    ViewData["Title"] = "Ta bort Koppling";
}

<h1>Ta bort Leverantör–Råvara Koppling</h1>

<h4>Leverantör: @Model.Leverantör?.Namn</h4>
<h4>Råvara: @Model.Råvara?.Namn</h4>

<form asp-action="Delete">
    <input type="hidden" asp-for="LeverantörId" />
    <input type="hidden" asp-for="RåvaraId" />
    <button class="btn btn-danger">Ta bort</button>
    <a asp-action="Index" class="btn btn-secondary">Avbryt</a>
</form>