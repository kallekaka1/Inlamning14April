@model MorMorsBageruMVC.Models.Råvara

@{
    ViewData["Title"] = "Skapa Råvara";
}

<h1>Skapa Råvara</h1>

<form asp-action="Create">
    <div class="form-group">
        <label>Artikelnummer</label>
        <input asp-for="Artikelnummer" class="form-control" />
    </div>

    <div class="form-group">
        <label>Namn</label>
        <input asp-for="Namn" class="form-control" />
    </div>

    <div class="form-group">
        <label>Pris per kg</label>
        <input asp-for="PrisPerKg" class="form-control" />
    </div>

    <div class="form-group">
        <label>Leverantör Id</label>
        <input asp-for="LeverantörId" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Spara</button>
    <a asp-action="Index" class="btn btn-secondary">Tillbaka</a>
</form>