@model IEnumerable<MorMorsBageruMVC.Models.InköpsRad>

@{
    ViewData["Title"] = "Inköpsrader";
}

<h1>Inköpsrader</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Skapa ny rad</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Inköp ID</th>
            <th>Datum</th>
            <th>Leverantör</th>
            <th>Råvara</th>
            <th>Mängd (kg)</th>
            <th>Pris per kg</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.InköpId</td>
                <td>@r.Inköp?.Datum.ToShortDateString()</td>
                <td>@r.Inköp?.Leverantör?.Namn</td>
                <td>@r.Råvara?.Namn</td>
                <td>@r.MängdKg</td>
                <td>@r.PrisPerKg</td>
                <td>
                    <a asp-action="Details" asp-route-inköpId="@r.InköpId" asp-route-råvaraId="@r.RåvaraId">Detaljer</a> |
                    <a asp-action="Edit" asp-route-inköpId="@r.InköpId" asp-route-råvaraId="@r.RåvaraId">Redigera</a> |
                    <a asp-action="Delete" asp-route-inköpId="@r.InköpId" asp-route-råvaraId="@r.RåvaraId">Ta bort</a>
                </td>
            </tr>
        }
    </tbody>
</table>