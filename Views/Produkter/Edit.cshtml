@model MorMorsBageruMVC.Models.Produkt

@{
    ViewData["Title"] = "Redigera Produkt";
}

<h1>Redigera Produkt</h1>

<form asp-action="Edit">

    <input type="hidden" asp-for="ProduktId" />

    <div class="form-group">
        <label>Namn</label>
        <input asp-for="Namn" class="form-control" />
    </div>

    <div class="form-group">
        <label>Kategori</label>
        <input asp-for="Kategori" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Spara</button>
    <a asp-action="Index" class="btn btn-secondary">Tillbaka</a>

</form>