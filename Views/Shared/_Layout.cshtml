<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Mormors Bageri Admin</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <!-- Global styles -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Admin PRO styles -->
    <link rel="stylesheet" href="~/css/admin.css" />
</head>

<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <h2 class="logo"><i class="fa-solid fa-bread-slice"></i> Bageri Admin</h2>

        <nav>
            <a href="/Dashboard"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
            <a href="/Leverantörer"><i class="fa-solid fa-truck"></i> Leverantörer</a>
            <a href="/Råvaror"><i class="fa-solid fa-apple-whole"></i> Råvaror</a>
            <a href="/Produkter"><i class="fa-solid fa-cake-candles"></i> Produkter</a>
            <a href="/Recept"><i class="fa-solid fa-book"></i> Recept</a>
            <a href="/ReceptRader"><i class="fa-solid fa-layer-group"></i> Receptrader</a>
            <a href="/Lager"><i class="fa-solid fa-box"></i> Lager</a>
            <a href="/Inköp"><i class="fa-solid fa-cart-shopping"></i> Inköp</a>
            <a href="/InköpsRader"><i class="fa-solid fa-list"></i> Inköpsrader</a>
            <a href="/LeverantörRåvara"><i class="fa-solid fa-link"></i> Kopplingar</a>
        </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="content">
        <div class="page-wrapper">
            @RenderBody()
        </div>
    </main>

</body>

</html>