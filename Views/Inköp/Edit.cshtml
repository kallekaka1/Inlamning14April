@model MorMorsBageruMVC.Models.Inköp

@{
    ViewData["Title"] = "Redigera Inköp";
}

<h1>Redigera Inköp</h1>

<form asp-action="Edit">

    <input type="hidden" asp-for="InköpId" />

    <div class="form-group">
        <label>Datum</label>
        <input asp-for="Datum" class="form-control" type="date" />
    </div>

    <div class="form-group">
        <label>Leverantör ID</label>
        <input asp-for="LeverantörId" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Spara</button>
    <a asp-action="Index" class="btn btn-secondary">Tillbaka</a>

</form>
