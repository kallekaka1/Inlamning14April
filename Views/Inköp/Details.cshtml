@model MorMorsBageruMVC.Models.Inköp

@{
    ViewData["Title"] = "Inköp Detaljer";
}

<h1>Inköp Detaljer</h1>

<table class="table">
    <tr>
        <th>Datum</th>
        <td>@Model.Datum.ToShortDateString()</td>
    </tr>
    <tr>
        <th>Leverantör</th>
        <td>@Model.Leverantör?.Namn</td>
    </tr>
</table>

<h3>Inköpsrader</h3>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Råvara</th>
            <th>Mängd (kg)</th>
            <th>Pris per kg</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Model.Rader)
        {
            <tr>
                <td>@row.Råvara?.Namn</td>
                <td>@row.MängdKg</td>
                <td>@row.PrisPerKg</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Edit" asp-route-id="@Model.InköpId" class="btn btn-primary">Redigera</a>
<a asp-action="Index" class="btn btn-secondary">Tillbaka</a>